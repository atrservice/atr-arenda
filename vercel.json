{
  "version": 2,
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": [
    "fra1"
  ],
  "env": {
    "NEXT_PUBLIC_SITE_URL": "https://avtovishki-arenda.ru"
  },
  "redirects": [
    {
      "source": "/arenda-avtovyshki",
      "destination": "/uslugi/avtovyshki",
      "permanent": true
    },
    {
      "source": "/arenda-kmu",
      "destination": "/uslugi/kmu",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}